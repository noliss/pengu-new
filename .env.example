# ====== TonConnect ======
# Публичный URL манифеста. ВАЖНО: кошелёк пользователя скачивает манифест
# сам, поэтому URL должен быть публично доступен по HTTPS.
# В dev тоже указываем публичный URL (gh-pages/твой CDN), а не localhost.
VITE_TONCONNECT_MANIFEST_URL=https://noliq.github.io/pengu-new/tonconnect-manifest.json

# ====== Backend API ======
VITE_API_URL=https://api.example.com
VITE_API_TIMEOUT_MS=15000

# ====== TON ======
# mainnet | testnet
VITE_TON_NETWORK=testnet
# Адрес master-контракта коллекции (для покупки NFT)
VITE_COLLECTION_MASTER_ADDRESS=
# Кошелёк-получатель для тестовых платежей
VITE_RECEIVER_WALLET_ADDRESS=

# ====== Observability ======
# Пусто -> Sentry отключён
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development

# ====== Misc ======
# Включить расширенный дебаг-лог в браузере
VITE_DEBUG=false
